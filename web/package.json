{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathPatterns='__tests__/unit' --passWithNoTests",
    "test:security": "jest --testPathPatterns='__tests__/security' --passWithNoTests",
    "test:integration": "jest --testPathPatterns='__tests__/integration' --passWithNoTests",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage --testPathPatterns='__tests__/(unit|security)' --passWithNoTests",
    "qa": "zsh ../scripts/qa.sh",
    "security-audit": "zsh ../scripts/security-audit.sh"
  },
  "dependencies": {
    "@axync/extract-json": "^1.1.3",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
